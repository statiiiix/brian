DATABASE_URL=postgresql://user:pass@host:5432/postgres
# Tests run in a dedicated `test` schema so they never truncate live `public` data.
# Append the search_path option so test tables are created/used in `test`:
TEST_DATABASE_URL=postgresql://user:pass@host:5432/postgres?options=-c%20search_path%3Dtest%2Cpublic
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4-mini
PORT=3001
STALE_DAYS=30
CAPTURE_CONFIDENCE_MIN=0.75
CAPTURE_SIM_MAX=0.2

# OAuth is configured once by the Brian team. Customers never provide these.
# The hosted API base is used to derive every provider callback URL.
BRIAN_OAUTH_BASE_URL=https://foydcrwyakpkisxtvzgr.supabase.co/functions/v1/brian
BRIAN_APP_URL=http://localhost:3000
CONNECTOR_ENCRYPTION_KEY=replace-with-32-random-bytes-as-64-hex-characters

# One provider registration per family. Microsoft covers SharePoint, OneDrive,
# Teams, and Outlook; Atlassian covers Jira and Confluence.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
ATLASSIAN_CLIENT_ID=
